{
  "manifest_version": 3,
  "name": "AI Job Automation – LinkedIn Helper",
  "description": "Extract LinkedIn job details (title, company, description) and send them to your local AI Job Automation System backend.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Analyze Job with AI"
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.naukri.com/*",
    "https://*.indeed.com/*",
    "https://*.glassdoor.com/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/jobs/*",
        "https://*.naukri.com/*",
        "https://*.indeed.com/*",
        "https://*.glassdoor.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

